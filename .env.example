# ============================================================
#  Web QLCV — biến môi trường
# ============================================================

# --- Database ---
# LOCAL (Docker Postgres — chạy: docker compose up -d):
DATABASE_URL="postgresql://qlcv:qlcv@localhost:5432/qlcv?schema=public"
DIRECT_URL="postgresql://qlcv:qlcv@localhost:5432/qlcv?schema=public"

# SUPABASE (production — lấy ở Settings → Database → Connection string):
#   - DATABASE_URL: dùng Connection Pooling (port 6543) + ?pgbouncer=true  (cho serverless Vercel)
#   - DIRECT_URL : dùng Direct connection (port 5432)                       (cho prisma migrate)
# DATABASE_URL="postgresql://postgres.<ref>:<pass>@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.<ref>:<pass>@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# --- Auth (NextAuth v5) ---
# Sinh chuỗi bí mật: npx auth secret   (hoặc PowerShell: [Convert]::ToBase64String((1..48|%{Get-Random -Max 256})))
AUTH_SECRET="thay-bang-chuoi-bi-mat-that"
# Production: đặt URL công khai (Vercel)
# AUTH_URL="https://your-app.vercel.app"
AUTH_TRUST_HOST="true"
