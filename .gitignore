# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Giữ template env (bỏ qua .env thật)
!.env.example

# Backup DB (dump JSON cục bộ — không đẩy lên git)
/backup

# File chứa thông tin nhạy cảm / cấu hình cục bộ — KHÔNG đẩy lên git
/docs/TAI-KHOAN-CAP-PHAT.xlsx
.claude/
.mcp.json

# docs nhạy cảm (chứa mật khẩu tạm) / quá khổ — KHÔNG đẩy lên git
/docs/_gen_accounts.py
/docs/_gen_guide.py
/docs/HUONG-DAN-SU-DUNG.docx
/docs/Qlcv@*
/docs/Data/

# temp Supabase sync creds (never commit)
prisma/import/supabase-sync.env
prisma/import/*.tmp.sql
.env.supabase.tmp
prisma/import/.pgpass

# Dump dữ liệu cục bộ (chứa passwordHash / dữ liệu thật) — KHÔNG đẩy lên git
prisma/import/backup-*.json
prisma/import/created-missing-*.json
prisma/import/local-backup-*.sql
prisma/import/prod-backup-*.sql
prisma/import/supabase-data.sql

# Tài liệu/ảnh thiết kế & artifact nghiệm thu (không cần trong repo)
