# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Giữ template env (bỏ qua .env thật)
!.env.example

# Backup DB (dump JSON cục bộ — không đẩy lên git)
/backup

# File chứa thông tin nhạy cảm / cấu hình cục bộ — KHÔNG đẩy lên git
/docs/TAI-KHOAN-CAP-PHAT.xlsx
.claude/
.mcp.json

# temp Supabase sync creds (never commit)
prisma/import/supabase-sync.env
prisma/import/*.tmp.sql
.env.supabase.tmp
prisma/import/.pgpass
