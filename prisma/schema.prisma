// Prisma schema — Web QLCV phòng BIM
// Postgres (Supabase). Tham khảo ../web-qlcv + WM_New.xlsx.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Enums ----------

enum UserRole {
  ADMIN // Admin
  LEVEL_1 // Cấp 1 — quản lý việc/dự án
  LEVEL_2 // Cấp 2 — tự cập nhật việc được giao
  LEVEL_3 // Cấp 3 — chỉ xem
}

enum TaskStatus {
  CHUA_LAM // Chưa làm
  DANG_LAM // Đang thực hiện
  HOAN_THANH // Hoàn thành
  TAM_DUNG // Tạm dừng
  // "Quá hạn" KHÔNG lưu — suy ra từ plannedEnd < hôm nay AND status != HOAN_THANH
}

enum TaskPriority {
  CAO // Cao
  TRUNG_BINH // Trung bình
  THAP // Thấp
}

enum ProjectStatus {
  DANG_THUC_HIEN // Đang thực hiện
  TAM_DUNG // Tạm dừng
  HOAN_THANH // Hoàn thành
}

enum NotificationType {
  TASK_ASSIGNED // Được giao việc
  TASK_DEADLINE_CHANGED // Việc của tôi bị dời hạn
  TASK_PRIORITY_CHANGED // Việc của tôi đổi ưu tiên
  TASK_DEADLINE_SOON // Sắp đến hạn (sinh lười khi đọc)
  TASK_APPROVAL_REQUESTED // Có việc (NV tự tạo) chờ bạn duyệt
  TASK_DEADLINE_CHANGE_REQUESTED // NV đề xuất dời hạn, chờ quản lý duyệt
  TASK_DELETE_REQUESTED // NV đề xuất xóa việc, chờ quản lý duyệt
}

// ---------- Danh mục (lookup) ----------

/// Nhóm công việc chính — Level 1 (6 nhóm: HTTC BIM, Đào tạo, Quản lý, Thanh tra, BIM Tools, QL phần mềm)
model WorkGroup {
  id        String   @id @default(cuid())
  code      String   @unique // "1".."6"
  abbr      String?  @unique // Viết tắt làm tiền tố Id công việc (vd "XD" → XD-001)
  name      String
  order     Int      @default(0)
  lastSeq   Int      @default(0) // Bộ đếm Id theo nhóm — cấp nguyên tử khi giao việc
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks         Task[]
  catalogItems  CatalogItem[]
  projectGroups ProjectGroup[]
}

/// Giá trị danh mục Level 2/3/5 theo từng Nhóm (nguồn gợi ý khi tạo công việc — sheet Data).
model CatalogItem {
  id          String   @id @default(cuid())
  workGroupId String
  level       Int // 2, 3, 5
  value       String
  parentId    String?  // level 3 → level 2 cha (chỉ dùng cho nhóm PT / BIM Tools)
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  projectGroupId String? // liên kết dự án (chỉ dùng cho nhóm PT BIM Tools)

  workGroup    WorkGroup     @relation(fields: [workGroupId], references: [id], onDelete: Cascade)
  parent       CatalogItem?  @relation("CatalogItemParent", fields: [parentId], references: [id], onDelete: SetNull)
  children     CatalogItem[] @relation("CatalogItemParent")
  projectGroup ProjectGroup? @relation(fields: [projectGroupId], references: [id], onDelete: SetNull)

  @@unique([workGroupId, level, value])
  @@index([workGroupId, level])
  @@index([parentId])
  @@index([projectGroupId])
}

/// Bộ môn / Tổ — Level 4 (BIM, KT, KC, MEPF, HT, IT, DI, DN...)
model Discipline {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
  tasks Task[]
}

/// Loại hình công trình (Nhà ở, Hạ tầng, TTTM, Công nghiệp...) — dùng cho báo cáo định mức.
model ConstructionType {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects Project[]
}

/// Giai đoạn dự án (Concept, TKCS, FEED, TKKT, TKBVTC, Thi công, Hoàn công, Vận hành)
model Phase {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[]
}

/// Dự án (cấp cha) — 1 mã = 1 dự án. Tên do người dùng đặt (seed tạm = mã).
/// Mỗi dự án chứa nhiều Hạng mục (= model Project bên dưới).
model ProjectGroup {
  id          String   @id @default(cuid())
  code        String   @unique // = mã dự án
  name        String   // tên dự án thật
  workGroupId String?  // null = chung (QL/TT BIM); non-null = thuộc nhóm CV cụ thể (PT...)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workGroup    WorkGroup?    @relation(fields: [workGroupId], references: [id])
  items        Project[]     // các hạng mục thuộc dự án
  catalogItems CatalogItem[] // hạng mục BIM Tools gắn với dự án này
}

/// Hạng mục của dự án (UI gọi "Hạng mục"; mã như B.DSHNQN.DMF + tên hạng mục).
model Project {
  id                 String        @id @default(cuid())
  groupId            String? // FK → ProjectGroup (Dự án cha); nullable trước backfill
  code               String // KHÔNG unique đơn lẻ: nhóm Quản lý BIM mỗi (mã + tên) là 1 dự án riêng
  name               String
  blockSystem        String? // Khối / Hệ thống trong hạng mục
  scale              String? // Quy mô công trình (nhập tay, dùng cho nhóm Quản lý BIM)
  status             ProjectStatus @default(DANG_THUC_HIEN)
  constructionTypeId String? // Loại hình công trình (cho báo cáo định mức)
  startDate          DateTime?
  packagingDate      DateTime? // Ngày đóng gói / bàn giao hạng mục
  endDate            DateTime?
  description        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?

  constructionType ConstructionType? @relation(fields: [constructionTypeId], references: [id])
  group            ProjectGroup?     @relation(fields: [groupId], references: [id])
  tasks            Task[]
  timeSheets       TimeSheetEntry[]

  @@index([code, name, constructionTypeId, blockSystem])
  @@index([status])
  @@index([constructionTypeId])
  @@index([groupId])
}

// ---------- Người dùng ----------

model User {
  id                 String    @id @default(cuid())
  username           String    @unique
  email              String    @unique
  fullName           String
  passwordHash       String
  mustChangePassword Boolean   @default(false)
  role               UserRole  @default(LEVEL_2)
  disciplineId       String?
  isActive           Boolean   @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  discipline    Discipline?      @relation(fields: [disciplineId], references: [id])
  assignments   TaskAssignee[]
  approvedTasks        Task[]  @relation("TaskApprover")
  tasksToApprove       Task[]  @relation("TaskStartApprover")
  endChangeRequests    Task[]  @relation("TaskEndChangeRequester")
  deleteRequests       Task[]  @relation("TaskDeleteRequester")
  timeSheets    TimeSheetEntry[]
  notifications Notification[]   @relation("NotifRecipient")

  @@index([disciplineId])
}

// ---------- Công việc (WBS) ----------

model Task {
  id        String  @id @default(cuid())
  // Phân loại
  workGroupId String // Level 1 (bắt buộc)
  projectId   String? // Dự án (nullable — nhóm HTTC/Đào tạo không gắn dự án)
  disciplineId String? // Level 4 (Bộ môn)
  phaseId      String? // Giai đoạn

  // Mã & cấp WBS
  sumId   String? // "3.B.DSHNQN.DMF.101"
  subId   String? // "101"
  seq     Int?    // Số chạy Id theo nhóm công việc (hiển thị "XD-001" ở Giao việc)
  wbsPath String // materialized path "01.02.03"
  level   Int     @default(1) // 1..5
  parentId String?

  // Nội dung các cấp
  level2 String? // Hạng mục
  level3 String? // Chi tiết / tên hạng mục / tên dự án con
  level5 String? // Đầu việc cụ thể
  name   String // tên hiển thị (= level5 hoặc level3...)

  // Thuộc tính
  priority        TaskPriority @default(TRUNG_BINH)
  status          TaskStatus   @default(CHUA_LAM)
  measureNorm     Boolean      @default(false) // (*) việc cần đo định mức
  progressPercent Int          @default(0)
  plannedStart    DateTime?
  plannedEnd      DateTime?
  actualEnd       DateTime?
  note            String?
  result          String? // Kết quả công việc (URL hoặc đường dẫn file)

  // Duyệt việc (chỉ Quản trị/Cấp 1) — null = chưa duyệt (ký duyệt SAU khi hoàn thành)
  approvedAt   DateTime?
  approvedById String?

  // Duyệt KHỞI TẠO (luồng mới, TRƯỚC khi làm): chỉ định người duyệt; chưa duyệt thì khóa nhập thời gian.
  // approverId != null  => việc cần duyệt khởi tạo; startApprovedAt = null => đang chờ duyệt.
  approverId      String?
  startApprovedAt DateTime?

  // Yêu cầu đổi ngày kết thúc (do người được giao gửi, cần quản lý duyệt).
  pendingPlannedEnd    DateTime?
  endChangeRequesterId String?   @db.VarChar(30)
  endChangeNote        String?   // Lý do đề xuất dời hạn

  // Yêu cầu xóa việc (đã được duyệt khởi tạo, cần quản lý duyệt xóa).
  deleteRequestedAt    DateTime?
  deleteRequesterId    String?   @db.VarChar(30)
  deleteRequestNote    String?   // Lý do đề xuất xóa

  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  workGroup  WorkGroup      @relation(fields: [workGroupId], references: [id])
  project    Project?       @relation(fields: [projectId], references: [id])
  discipline Discipline?    @relation(fields: [disciplineId], references: [id])
  phase      Phase?         @relation(fields: [phaseId], references: [id])
  parent        Task?            @relation("TaskTree", fields: [parentId], references: [id])
  children      Task[]           @relation("TaskTree")
  approvedBy           User?  @relation("TaskApprover", fields: [approvedById], references: [id])
  approver             User?  @relation("TaskStartApprover", fields: [approverId], references: [id])
  endChangeRequester   User?  @relation("TaskEndChangeRequester", fields: [endChangeRequesterId], references: [id])
  deleteRequester      User?  @relation("TaskDeleteRequester", fields: [deleteRequesterId], references: [id])
  assignees     TaskAssignee[]
  timeSheets    TimeSheetEntry[]
  notifications Notification[]

  @@unique([workGroupId, seq])
  @@index([workGroupId])
  @@index([projectId])
  @@index([disciplineId])
  @@index([status])
  @@index([wbsPath])
  @@index([sumId])
  @@index([approverId])
}

/// Bảng nối nhiều-nhiều: 1 công việc có thể có nhiều người (Nhân sự 01/02/03)
model TaskAssignee {
  id     String @id @default(cuid())
  taskId String
  userId String
  roleNo Int    @default(1) // 1 = chính, 2/3 = phối hợp

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
}

// ---------- Nhật ký công việc (Timesheet) ----------

model TimeSheetEntry {
  id        String    @id @default(cuid())
  userId    String
  taskId    String?
  projectId String?
  date      DateTime  @db.Date
  hours     Decimal   @db.Decimal(4, 2)
  note      String?
  lockedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user    User     @relation(fields: [userId], references: [id])
  task    Task?    @relation(fields: [taskId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])

  @@index([userId, date])
  @@index([taskId])
}

// ---------- Thông báo (in-app) ----------

/// Thông báo trong app (chuông). actorId = người gây ra (nullable cho nhắc hệ thống).
/// dedupeKey = khóa chống trùng cho thông báo sinh lười (vd nhắc "sắp đến hạn").
model Notification {
  id        String           @id @default(cuid())
  userId    String // người NHẬN
  actorId   String? // người gây ra (người giao/đổi). Null = hệ thống.
  type      NotificationType
  taskId    String?
  title     String
  body      String?
  dedupeKey String?          @unique
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User  @relation("NotifRecipient", fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt])
}
